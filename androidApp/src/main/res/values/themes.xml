<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme — Compose handles all visual styling -->
    <style name="Theme.MorningAgent" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- System splash: same dark canvas, static violet orb, hands off to LaunchScreen -->
    <style name="Theme.MorningAgent.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_orb_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.MorningAgent</item>
    </style>
</resources>
