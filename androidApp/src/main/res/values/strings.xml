    <!-- Dawn (05:00–08:59) -->
    <string name="greeting_dawn">Good morning, Luna.</string>
    <string name="sub_dawn">Fresh start. Three things matter today.</string>
    <string name="runlabel_dawn">Begin the day</string>
    <string name="status_dawn">Briefing ready</string>
    <string name="quote_dawn">Pick one win this morning, then build momentum. Start with the SDK doc — your mind is sharpest now, and it unblocks two downstream tasks.</string>

    <!-- Midday (09:00–11:59) -->
    <string name="greeting_midday">Mid-morning, Luna.</string>
    <string name="sub_midday">Halfway through your sharpest hours.</string>
    <string name="runlabel_midday">Refresh briefing</string>
    <string name="status_midday">Last run 09:02</string>
    <string name="quote_midday">Two of three still untouched. Close the PR before lunch — Maya is online, and a quick approval lets the next deploy go out on time.</string>

    <!-- Afternoon (12:00–16:59) -->
    <string name="greeting_afternoon_v4">Good afternoon, Luna.</string>
    <string name="sub_afternoon">Tidy the loose threads before dusk.</string>
    <string name="runlabel_afternoon">Refresh briefing</string>
    <string name="status_afternoon">Resting</string>
    <string name="quote_afternoon">Don\'t start anything new. Close the PR review and the design replies — both are quick, and you\'ll feel lighter by four.</string>

    <!-- Evening (17:00–20:59) -->
    <string name="greeting_evening_v4">Good evening, Luna.</string>
    <string name="sub_evening">Wind down. Tomorrow is set.</string>
    <string name="runlabel_evening">Confirm tomorrow</string>
    <string name="status_evening">Set for 09:00</string>
    <string name="quote_evening">Tomorrow is set — three high-priority items, queued. The SDK doc has the longest tail; everything else fits around it.</string>

    <!-- Night (21:00–04:59) -->
    <string name="greeting_night">It\'s late, Luna.</string>
    <string name="sub_night">Sleep on it. The agent has tomorrow.</string>
    <string name="runlabel_night">Plan tomorrow</string>
    <string name="status_night">Quiet hours</string>
    <string name="quote_night">Put it down. You closed six of nine today, including the auth refactor. The doc can wait one more sleep.</string>

