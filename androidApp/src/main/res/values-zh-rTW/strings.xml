    <!-- v4 — per-slot copy -->

    <!-- Dawn (05:00–08:59) -->
    <string name="greeting_dawn">早安，Luna。</string>
    <string name="sub_dawn">全新的開始。今天有三件重要的事。</string>
    <string name="runlabel_dawn">開始新的一天</string>
    <string name="status_dawn">簡報就緒</string>
    <string name="quote_dawn">今早先選一件能完成的事，然後建立節奏。先從 SDK 文件開始 — 你現在思緒最清晰，而且它能解鎖兩個後續任務。</string>

    <!-- Midday (09:00–11:59) -->
    <string name="greeting_midday">上午好，Luna。</string>
    <string name="sub_midday">最高效時段的中場。</string>
    <string name="runlabel_midday">重新整理簡報</string>
    <string name="status_midday">上次執行 09:02</string>
    <string name="quote_midday">三件事中還有兩件沒動。午餐前把 PR 結掉 — Maya 在線上，快速審核就能讓下一次部署準時出去。</string>

    <!-- Afternoon (12:00–16:59) -->
    <string name="greeting_afternoon_v4">午安，Luna。</string>
    <string name="sub_afternoon">天黑前把鬆散的線收好。</string>
    <string name="runlabel_afternoon">重新整理簡報</string>
    <string name="status_afternoon">休息中</string>
    <string name="quote_afternoon">別開始新的事了。把 PR 審核和設計回覆收尾 — 兩個都很快，四點前你會輕鬆很多。</string>

    <!-- Evening (17:00–20:59) -->
    <string name="greeting_evening_v4">晚上好，Luna。</string>
    <string name="sub_evening">放鬆。明天都安排好了。</string>
    <string name="runlabel_evening">確認明天</string>
    <string name="status_evening">已排定 09:00</string>
    <string name="quote_evening">明天都安排好了 — 三個高優先項目已排入。SDK 文件需要最多時間，其他的可以穿插進行。</string>

    <!-- Night (21:00–04:59) -->
    <string name="greeting_night">很晚了，Luna。</string>
    <string name="sub_night">放下吧。助理會處理明天的事。</string>
    <string name="runlabel_night">規劃明天</string>
    <string name="status_night">靜音時段</string>
    <string name="quote_night">放下吧。你今天完成了九個中的六個，包括認證重構。文件可以再睡一晚。</string>

